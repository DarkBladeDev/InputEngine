{
	"schemaVersion": 1,
	"id": "input-engine",
	"version": "${version}",
	"name": "InputEngine",
	"description": "A Fabric mod that captures client-side keystrokes and sends them to the server.",
	"authors": [
		"DarkbladeDev"
	],
	"contact": {
		"homepage": "https://github.com/DarkbladeDev/InputEngine",
		"sources": "https://github.com/DarkbladeDev/InputEngine"
	},
	"license": "MIT",
	"icon": "assets/input-engine/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			"dev.darkblade.mod.input_engine.InputEngine"
		],
		"client": [
			"dev.darkblade.mod.input_engine.client.InputEngineClient"
		]
	},
	"mixins": [
		"input-engine.mixins.json"
	],
	"depends": {
		"fabricloader": ">=0.19.3",
		"minecraft": ">=1.21.1 <=1.21.11",
		"java": ">=21",
		"fabric-api": "*"
	}
}